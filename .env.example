# Copy to .env on the Oracle VM. Never commit .env.

# Public API URL (browser will call this) — use your VM public IP
PUBLIC_API_URL=http://YOUR_ORACLE_PUBLIC_IP:8000/api

# Allow your Vercel frontend (and optional Oracle frontend) to call the API
# Example: https://auto-scoring-xxxx.vercel.app
CORS_ORIGINS=https://YOUR_VERCEL_APP.vercel.app

# Database — change these
POSTGRES_USER=autoscoring
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=autoscoring

# JWT — long random string
SECRET_KEY=change-me-to-a-long-random-secret
