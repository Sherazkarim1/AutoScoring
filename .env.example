# Copy to .env on the server and edit values before `docker compose up --build`.
# Never commit .env.

# Public URLs as the browser sees them (no trailing slash)
PUBLIC_FRONTEND_URL=http://YOUR_SERVER_IP:5173
PUBLIC_API_URL=http://YOUR_SERVER_IP:8000/api

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://YOUR_SERVER_IP:5173

# Database (change password on a real server)
POSTGRES_USER=autoscoring
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=autoscoring

# JWT signing key — generate a long random string
SECRET_KEY=change-me-to-a-long-random-secret
